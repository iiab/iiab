network:
  ethernets:
    {{ iiab_wireless_lan_iface }}:
      dhcp4: false
      dhcp6: false
      optional: true
{% if iiab_wireless_lan_iface == "ap0" or iiab_wireless_lan_iface == "wld0" %}
      match:
        macaddress: {{ ap0_mac_addr }}
      set-name: {{ iiab_wireless_lan_iface }}
{% endif %}
  bridges:
    br0:
      interfaces:
      - {{ iiab_wireless_lan_iface }}
